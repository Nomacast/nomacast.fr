# ─── Redirections 301 (pages supprimées) ─────────────────────────────────────
# Cas clients supprimés → redirection vers la page liste des cas clients
# Pourquoi : ces URLs ont peut-être été indexées ou partagées.
# Plutôt qu'une 404, on renvoie le visiteur vers la liste des cas restants.

Redirect 301 /cas-client-ag-maif.html https://www.nomacast.fr/cas-clients.html
Redirect 301 /cas-client-pret-a-manger.html https://www.nomacast.fr/cas-clients.html
Redirect 301 /default_index.html https://www.nomacast.fr/


# ─── Pages d'erreur personnalisées ───────────────────────────────────────────
# Sert la page 404.html avec design Nomacast au lieu de la 404 par défaut LWS.
# Le chemin commence par / (racine du domaine).

ErrorDocument 404 /404.html
ErrorDocument 403 /404.html
ErrorDocument 500 /404.html


# ─── Compression Gzip / Brotli ───────────────────────────────────────────────
# Réduit le poids des fichiers texte de 60-80% avant transmission.
# Effet direct sur Core Web Vitals (LCP, FCP) → boost SEO Google.

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html
  AddOutputFilterByType DEFLATE text/css
  AddOutputFilterByType DEFLATE text/plain
  AddOutputFilterByType DEFLATE text/xml
  AddOutputFilterByType DEFLATE application/xml
  AddOutputFilterByType DEFLATE application/xhtml+xml
  AddOutputFilterByType DEFLATE application/rss+xml
  AddOutputFilterByType DEFLATE application/javascript
  AddOutputFilterByType DEFLATE application/x-javascript
  AddOutputFilterByType DEFLATE application/json
  AddOutputFilterByType DEFLATE application/ld+json
  AddOutputFilterByType DEFLATE application/x-font-ttf
  AddOutputFilterByType DEFLATE application/vnd.ms-fontobject
  AddOutputFilterByType DEFLATE font/opentype
  AddOutputFilterByType DEFLATE font/ttf
  AddOutputFilterByType DEFLATE font/eot
  AddOutputFilterByType DEFLATE image/svg+xml
  AddOutputFilterByType DEFLATE image/x-icon
</IfModule>

<IfModule mod_brotli.c>
  AddOutputFilterByType BROTLI_COMPRESS text/html
  AddOutputFilterByType BROTLI_COMPRESS text/css
  AddOutputFilterByType BROTLI_COMPRESS text/plain
  AddOutputFilterByType BROTLI_COMPRESS text/xml
  AddOutputFilterByType BROTLI_COMPRESS application/javascript
  AddOutputFilterByType BROTLI_COMPRESS application/json
  AddOutputFilterByType BROTLI_COMPRESS application/ld+json
  AddOutputFilterByType BROTLI_COMPRESS image/svg+xml
</IfModule>


# ─── Cache navigateur (Expires headers) ──────────────────────────────────────
# Indique au navigateur combien de temps garder un fichier en cache local.
# Visiteurs récurrents = chargement quasi-instantané (pas de re-téléchargement).

<IfModule mod_expires.c>
  ExpiresActive On

  # Pages HTML : cache court (pour que les modifs SEO/contenu se voient vite)
  ExpiresByType text/html "access plus 1 hour"

  # CSS et JavaScript : cache long (rarement modifiés)
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType application/x-javascript "access plus 1 month"

  # Images : cache très long (jamais modifiées)
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"

  # Polices : cache très long
  ExpiresByType font/ttf "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType application/font-woff "access plus 1 year"
  ExpiresByType application/font-woff2 "access plus 1 year"

  # Vidéo : cache long
  ExpiresByType video/mp4 "access plus 1 month"
  ExpiresByType video/webm "access plus 1 month"

  # Documents structurés (sitemap, robots, llms.txt) : cache court
  ExpiresByType application/xml "access plus 1 day"
  ExpiresByType text/xml "access plus 1 day"
  ExpiresByType text/plain "access plus 1 day"

  # JSON : cache court
  ExpiresByType application/json "access plus 1 day"
  ExpiresByType application/ld+json "access plus 1 day"

  # Par défaut
  ExpiresDefault "access plus 1 week"
</IfModule>


# ─── Cache-Control headers (renforcement) ────────────────────────────────────

<IfModule mod_headers.c>
  # Images : cache navigateur + CDN
  <FilesMatch "\.(jpg|jpeg|png|gif|webp|svg|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # CSS / JS : cache navigateur + CDN
  <FilesMatch "\.(css|js)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>

  # Polices
  <FilesMatch "\.(ttf|woff|woff2|eot)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
    Header set Access-Control-Allow-Origin "*"
  </FilesMatch>

  # HTML : cache court
  <FilesMatch "\.(html|htm)$">
    Header set Cache-Control "public, max-age=3600, must-revalidate"
  </FilesMatch>
</IfModule>


# ─── WebP transparent : sert .webp si le navigateur le supporte ──────────────
# Sans modifier le HTML : <img src="logo.png"> servira automatiquement
# logo.png.webp (s'il existe à côté de logo.png) aux navigateurs compatibles.
# Compatible avec 97%+ des navigateurs en 2026 (Chrome, Firefox, Safari, Edge).
# Fallback automatique sur PNG/JPG pour les vieux navigateurs.

<IfModule mod_rewrite.c>
  RewriteEngine On

  # Si le navigateur accepte le format WebP
  RewriteCond %{HTTP_ACCEPT} image/webp

  # Et que la version .webp existe sur le serveur (logo.png.webp à côté de logo.png)
  RewriteCond %{REQUEST_FILENAME} \.(jpe?g|png)$
  RewriteCond %{REQUEST_FILENAME}.webp -f

  # Alors sert le .webp à la place du .png/.jpg
  RewriteRule (.+)\.(jpe?g|png)$ $1.$2.webp [T=image/webp,E=accept:1,L]
</IfModule>

<IfModule mod_headers.c>
  # Indique aux CDN/proxies que la réponse varie selon Accept
  # (sinon ils peuvent servir le mauvais format en cache)
  <FilesMatch "\.(jpe?g|png)$">
    Header append Vary Accept
  </FilesMatch>
</IfModule>

# Type MIME WebP (sécurité — souvent déjà déclaré côté serveur)
<IfModule mod_mime.c>
  AddType image/webp .webp
</IfModule>


# ─── Headers de sécurité ─────────────────────────────────────────────────────
# Renforce la sécurité du site et envoie un signal de qualité à Google.

<IfModule mod_headers.c>
  # HSTS : force HTTPS pendant 1 an, même pour les sous-domaines
  # ⚠️ Une fois activé, désactivation difficile. Ton site est en HTTPS partout, OK.
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains" env=HTTPS

  # Empêche le clickjacking (ton site dans une iframe d'un autre site)
  Header always set X-Frame-Options "SAMEORIGIN"

  # Empêche le MIME-sniffing (force le navigateur à respecter les types déclarés)
  Header always set X-Content-Type-Options "nosniff"

  # Politique de référent : envoie le referer en HTTPS, pas en HTTP
  Header always set Referrer-Policy "strict-origin-when-cross-origin"

  # Permissions Policy : désactive les API non utilisées (caméra, micro, etc.)
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(self)"
</IfModule>


# ─── Optimisations diverses ──────────────────────────────────────────────────

# Désactive l'ETag (évite les conflits avec mod_expires)
<IfModule mod_headers.c>
  Header unset ETag
</IfModule>
FileETag None

# Empêche l'affichage du contenu des dossiers
Options -Indexes

# Force l'encoding UTF-8 par défaut
AddDefaultCharset UTF-8


